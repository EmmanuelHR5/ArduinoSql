<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ProgramablesAvalonia.MainWindow"
        Width="500" Height="350"
        Title="Puerto Serial">

    <StackPanel Margin="20" Spacing="10">

        <ComboBox x:Name="cmbPuertos" Width="200"/>

        <Button x:Name="btnConectar"
                Content="Conectar"
                Width="120"
                Click="btnConectar_Click"/>

        <TextBox x:Name="rtbMenssage"
                 AcceptsReturn="True"
                 Height="200"/>

    </StackPanel>

</Window>